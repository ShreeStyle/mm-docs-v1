<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{content.title}}</title>
    <style>
        {{{brandCSS}}}
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: var(--font-primary, 'Inter', 'Arial', sans-serif);
            line-height: 1.6;
            color: #2d3748;
            background: #ffffff;
            font-size: 14px;
        }
        
        .document-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            min-height: 100vh;
            border: 3px solid var(--primary-color, #1e40af);
            border-radius: 16px;
            margin-top: 20px;
            margin-bottom: 20px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--primary-color, #1e40af);
        }
        
        .company-name {
            font-size: 36px;
            font-weight: 700;
            color: var(--primary-color, #1e40af);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .document-title {
            font-size: 28px;
            font-weight: 600;
            color: #1a202c;
            margin: 20px 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .certificate-number {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 20px;
        }
        
        .employee-section {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            padding: 32px;
            border-radius: 16px;
            margin: 32px 0;
            text-align: center;
            border: 2px solid var(--primary-color, #1e40af);
        }
        
        .employee-name {
            font-size: 32px;
            font-weight: 700;
            color: var(--primary-color, #1e40af);
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .employment-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin: 24px 0;
        }
        
        .detail-item {
            text-align: center;
            padding: 16px;
            background: white;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
        }
        
        .detail-label {
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        
        .detail-value {
            font-size: 18px;
            font-weight: 700;
            color: #1a202c;
        }
        
        .content-section {
            margin: 32px 0;
            text-align: justify;
            line-height: 1.8;
        }
        
        .performance-text {
            font-size: 16px;
            margin: 24px 0;
            padding: 24px;
            background: #f8fafc;
            border-left: 4px solid var(--primary-color, #1e40af);
            border-radius: 8px;
        }
        
        .achievements-section {
            margin: 32px 0;
        }
        
        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--primary-color, #1e40af);
            margin-bottom: 16px;
            text-align: center;
            text-transform: uppercase;
        }
        
        .achievements-list {
            list-style: none;
            padding: 0;
        }
        
        .achievements-list li {
            padding: 12px 0;
            padding-left: 30px;
            position: relative;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .achievements-list li:before {
            content: "★";
            position: absolute;
            left: 0;
            color: var(--primary-color, #1e40af);
            font-size: 18px;
        }
        
        .recommendation {
            background: linear-gradient(135deg, var(--primary-color, #1e40af) 0%, #3b82f6 100%);
            color: white;
            padding: 24px;
            border-radius: 12px;
            text-align: center;
            margin: 32px 0;
            font-size: 16px;
            font-weight: 500;
        }
        
        .signature-section {
            margin-top: 48px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
        }
        
        .signature-box {
            text-align: center;
            padding: 24px;
            border: 2px dashed var(--primary-color, #1e40af);
            border-radius: 12px;
        }
        
        .date-issued {
            text-align: center;
            margin-top: 32px;
            font-size: 14px;
            color: #64748b;
        }
    </style>
</head>
<body>
    <div class="document-container">
        <div class="header">
            <div class="company-name">{{content.companyName}}</div>
            <div class="document-title">{{content.title}}</div>
            <div class="certificate-number">Certificate No: EXP-{{content.employeeId}}-2024</div>
        </div>

        <div class="employee-section">
            <div style="font-size: 18px; margin-bottom: 16px; color: #64748b;">This is to certify that</div>
            <div class="employee-name">{{content.employeeName}}</div>
            <div style="font-size: 16px; color: #64748b;">has been employed with our organization</div>
            
            <div class="employment-details">
                <div class="detail-item">
                    <div class="detail-label">Position</div>
                    <div class="detail-value">{{content.position}}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Department</div>
                    <div class="detail-value">{{content.department}}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">From</div>
                    <div class="detail-value">{{content.employmentPeriod.startDate}}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">To</div>
                    <div class="detail-value">{{content.employmentPeriod.endDate}}</div>
                </div>
            </div>
        </div>

        <div class="performance-text">
            {{content.workPerformance}}
        </div>

        <div class="achievements-section">
            <div class="section-title">Key Achievements</div>
            <ul class="achievements-list">
                {{#each content.keyAchievements}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>

        <div class="content-section">
            <p><strong>Character Assessment:</strong> {{content.characterAssessment}}</p>
            <br>
            <p><strong>Reason for Leaving:</strong> {{content.reasonForLeaving}}</p>
        </div>

        <div class="recommendation">
            {{content.recommendation}}
        </div>

        <div class="signature-section">
            <div class="signature-box">
                <p><strong>Authorized Signatory</strong></p>
                <br><br>
                <p>{{content.authorizedSignatory.name}}</p>
                <p>{{content.authorizedSignatory.designation}}</p>
                <p>{{content.authorizedSignatory.company}}</p>
            </div>
            <div class="signature-box">
                <p><strong>Company Seal</strong></p>
                <br><br><br>
                <p>Official Company Seal</p>
            </div>
        </div>

        <div class="date-issued">
            <p><strong>Date of Issue:</strong> {{content.date}}</p>
            <p><strong>Contact for Verification:</strong> {{content.contactForVerification}}</p>
        </div>
    </div>
</body>
</html>