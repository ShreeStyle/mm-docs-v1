<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 0;
            color: #111827;
        }
        .page {
            padding: 40px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }
        .company-info {
            display: flex;
            gap: 15px;
        }
        .logo-placeholder {
            width: 60px;
            height: 60px;
            background-color: #F3F4F6;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9CA3AF;
            font-size: 10px;
            font-weight: bold;
        }
        .company-details h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
        }
        .company-details p {
            margin: 2px 0;
            font-size: 12px;
            color: #6B7280;
        }
        .invoice-title {
            color: #10B981;
            font-size: 36px;
            font-weight: 900;
            margin: 0;
            letter-spacing: 2px;
        }
        .details-grid {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 25px;
        }
        .details-table {
            border-collapse: collapse;
            border: 1px solid #E5E7EB;
        }
        .details-table td {
            padding: 6px 12px;
            font-size: 11px;
            border: 1px solid #E5E7EB;
        }
        .details-label {
            font-weight: bold;
            background-color: #F9FAFB;
        }
        .section-header {
            background-color: #10B981;
            color: white;
            padding: 8px 15px;
            font-weight: bold;
            font-size: 14px;
            text-transform: uppercase;
            margin-bottom: 15px;
        }
        .bill-ship-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }
        .address-box {
            padding: 15px;
            border: 1px solid #E5E7EB;
            min-height: 100px;
            font-size: 13px;
        }
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        .items-table th {
            background-color: #10B981;
            color: white;
            padding: 10px;
            text-align: left;
            font-size: 12px;
        }
        .items-table td {
            padding: 10px;
            border: 1px solid #E5E7EB;
            font-size: 12px;
        }
        .items-table tr:nth-child(even) {
            background-color: #F9FAFB;
        }
        .summary-container {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 40px;
        }
        .terms-box {
            border: 1px solid #E5E7EB;
            padding: 15px;
            font-size: 11px;
            min-height: 120px;
        }
        .summary-table {
            width: 100%;
            border-collapse: collapse;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 13px;
            border-bottom: 1px solid #E5E7EB;
        }
        .total-row {
            background-color: #E5E7EB;
            padding: 12px 10px;
            font-weight: bold;
            font-size: 18px;
            margin-top: 10px;
            display: flex;
            justify-content: space-between;
        }
        .total-amount {
            color: #10B981;
        }
        .footer-note {
            text-align: center;
            margin-top: 50px;
            color: #6B7280;
            font-size: 12px;
        }
        .footer-thanks {
            font-weight: 900;
            color: #111827;
            font-style: italic;
            font-size: 18px;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="header">
            <div class="company-info">
                <div class="logo-placeholder">LOGO</div>
                <div class="company-details">
                    <h2>{{companyName}}</h2>
                    <p>{{companyAddress}}</p>
                    <p><strong>GSTIN:</strong> {{gstNumber}}</p>
                </div>
            </div>
            <h1 class="invoice-title">TAX INVOICE</h1>
        </div>

        <div class="details-grid">
            <table class="details-table">
                <tr>
                    <td class="details-label">DATE</td>
                    <td>{{invoiceDate}}</td>
                </tr>
                <tr>
                    <td class="details-label">INVOICE #</td>
                    <td style="font-weight: bold;">{{invoiceNumber}}</td>
                </tr>
                <tr>
                    <td class="details-label">CUSTOMER ID</td>
                    <td>{{customerId}}</td>
                </tr>
                <tr>
                    <td class="details-label">DUE DATE</td>
                    <td>{{dueDate}}</td>
                </tr>
            </table>
        </div>

        <div class="bill-ship-container">
            <div>
                <div class="section-header">BILL TO</div>
                <div class="address-box">
                    <strong>{{clientName}}</strong><br>
                    {{#if billToAddress}}
                        {{{billToAddress}}}
                    {{/if}}
                    {{#if clientGST}}
                        <br><strong>GSTIN:</strong> {{clientGST}}
                    {{/if}}
                </div>
            </div>
            <div>
                <div class="section-header">SHIP TO</div>
                <div class="address-box">
                    <strong>{{shipToName}}</strong><br>
                    {{#if shipToAddress}}
                        {{{shipToAddress}}}
                    {{/if}}
                </div>
            </div>
        </div>

        <table class="items-table">
            <thead>
                <tr>
                    <th>No.</th>
                    <th>PRODUCT</th>
                    <th>DESCRIPTION</th>
                    <th style="text-align: center;">QTY</th>
                    <th style="text-align: right;">UNIT PRICE</th>
                    <th style="text-align: right;">AMOUNT</th>
                </tr>
            </thead>
            <tbody>
                {{#each items}}
                <tr>
                    <td style="width: 30px;">{{add @index 1}}</td>
                    <td>{{product}}</td>
                    <td>{{description}}</td>
                    <td style="text-align: center; width: 50px;">{{qty}}</td>
                    <td style="text-align: right; width: 100px;">₹{{numberFormat unitPrice}}</td>
                    <td style="text-align: right; width: 100px; font-weight: bold;">₹{{numberFormat total}}</td>
                </tr>
                {{/each}}
                {{#if (lt (length items) 5)}}
                    {{#each (range (length items) 5)}}
                    <tr style="height: 35px;">
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                    {{/each}}
                {{/if}}
            </tbody>
        </table>

        <div class="summary-container">
            <div>
                <div style="background-color: #10B981; color: white; padding: 5px 12px; font-weight: bold; font-size: 12px;">TERMS & CONDITIONS</div>
                <div class="terms-box">
                    {{{terms}}}
                </div>
            </div>
            <div>
                <div class="summary-row">
                    <span style="font-weight: 600;">Subtotal</span>
                    <span>₹{{numberFormat subtotal}}</span>
                </div>
                <div class="summary-row">
                    <span style="font-weight: 600;">Discount</span>
                    <span>₹{{numberFormat discount}}</span>
                </div>
                <div class="summary-row">
                    <span style="font-weight: 600;">Tax Amount ({{taxRate}}%)</span>
                    <span>₹{{numberFormat taxAmount}}</span>
                </div>
                {{#if otherCharges}}
                <div class="summary-row">
                    <span style="font-weight: 600;">Other Charges</span>
                    <span>₹{{numberFormat otherCharges}}</span>
                </div>
                {{/if}}
                <div class="total-row">
                    <span>TOTAL</span>
                    <span class="total-amount">₹{{numberFormat total}}</span>
                </div>
                <div style="text-align: center; margin-top: 15px; font-size: 11px; color: #6B7280;">
                    Make all checks payable to<br>
                    <strong>{{companyName}}</strong>
                </div>
            </div>
        </div>

        <div class="footer-note">
            <p>If you have any questions about this invoice, please contact<br>
            <strong>{{companyName}}</strong></p>
            <div class="footer-thanks">Thank You For Your Business!</div>
        </div>
    </div>
</body>
</html>