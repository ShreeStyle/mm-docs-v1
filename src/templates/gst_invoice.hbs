<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GST Invoice</title>
    <style>
        body {
            font-family: 'Times New Roman', serif;
            line-height: 1.6;
            color: #000;
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            background: white;
            font-size: 12pt;
        }
        .header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 2px solid #000;
            padding-bottom: 20px;
        }
        .company-name {
            font-size: 20pt;
            font-weight: bold;
            color: #000;
            margin-bottom: 8px;
            text-transform: uppercase;
        }
        .document-title {
            font-size: 18pt;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 30px 0;
            text-align: center;
            color: #000;
            text-decoration: underline;
        }
        .invoice-details {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }
        .details-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            border: 2px solid #000;
        }
        .details-table th,
        .details-table td {
            border: 1px solid #000;
            padding: 12px;
            text-align: left;
            font-size: 11pt;
        }
        .details-table th {
            background-color: #f5f5f5;
            font-weight: bold;
        }
        .total-section {
            margin-top: 20px;
            border: 2px solid #000;
            padding: 15px;
            background-color: #f9f9f9;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="company-name">{{companyName}}</div>
        <div>{{companyAddress}}</div>
        <div><strong>GST No:</strong> {{gstNumber}}</div>
    </div>

    <div class="document-title">Tax Invoice</div>

    <div class="invoice-details">
        <div>
            <p><strong>Invoice No:</strong> {{invoiceNumber}}</p>
            <p><strong>Date:</strong> {{invoiceDate}}</p>
        </div>
        <div>
            <p><strong>Bill To:</strong></p>
            <p><strong>{{clientName}}</strong></p>
            <p><strong>GST No:</strong> {{clientGST}}</p>
        </div>
    </div>

    <table class="details-table">
        <tr>
            <th>Description</th>
            <th>Amount</th>
        </tr>
        <tr>
            <td>{{serviceDescription}}</td>
            <td>₹{{baseAmount}}</td>
        </tr>
    </table>

    <div class="total-section">
        <p><strong>Base Amount:</strong> ₹{{baseAmount}}</p>
        <p><strong>CGST (9%):</strong> ₹{{#multiply baseAmount 0.09}}{{/multiply}}</p>
        <p><strong>SGST (9%):</strong> ₹{{#multiply baseAmount 0.09}}{{/multiply}}</p>
        <p><strong>Total Amount:</strong> ₹{{#multiply baseAmount 1.18}}{{/multiply}}</p>
    </div>
</body>
</html>