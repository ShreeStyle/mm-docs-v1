<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employment Offer Letter</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Great+Vibes&display=swap" rel="stylesheet">
    <style>
        @page {
            size: A4;
            margin: 0;
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'Montserrat', -apple-system, sans-serif;
            background: #ffffff;
            color: #333333;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        
        .a4-container {
            width: 100%;
            height: 100%;
            min-height: 100vh;
            position: relative;
            background: white;
            overflow: hidden;
            padding: 30mm 20mm 35mm 25mm;
            margin: 0;
            box-sizing: border-box;
        }

        /* Scalable SVG Backgrounds */
        .shape-top-left {
            position: absolute;
            top: 0;
            left: 0;
            width: 80mm;
            height: 70mm;
            z-index: 1;
            pointer-events: none;
        }
        .shape-bottom-right {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 90mm;
            height: 80mm;
            z-index: 1;
            pointer-events: none;
        }

        /* Main Content Layer */
        .content-layer {
            position: relative;
            z-index: 2;
        }

        /* Header Area */
        .header-area {
            text-align: center;
            margin-bottom: 20mm;
        }
        
        .company-name {
            font-size: 26px;
            font-weight: 800;
            color: #1a5632;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
        }

        .doc-title-wrapper {
            margin-bottom: 30px;
        }

        .doc-title {
            font-size: 14px;
            font-weight: 700;
            color: #1a5632;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
            border-bottom: 2px solid #1a5632;
            padding-bottom: 6px;
        }

        /* Info Block */
        .info-block {
            margin-bottom: 25px;
            font-size: 12px;
            line-height: 1.8;
        }
        
        .info-row {
            display: flex;
        }
        
        .info-label {
            font-weight: 700;
            width: 80px;
            color: #1a5632;
        }
        
        .info-value {
            color: #333333;
            font-weight: 500;
        }

        /* Body Typography */
        .body-text {
            font-size: 12.5px;
            line-height: 1.7;
            color: #333;
            text-align: justify;
            margin-bottom: 30px;
        }
        .body-text p {
            margin-bottom: 14px;
        }
        .body-text strong {
            color: #1a5632;
            font-weight: 600;
        }

        /* Signature Area */
        .signature-area {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            page-break-inside: avoid;
        }
        
        .signature-block {
            width: 45%;
        }

        .sig-label {
            font-size: 10px;
            font-weight: 700;
            color: #7cb899;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 40px;
        }

        .sig-line {
            border-top: 1px solid #1a5632;
            padding-top: 8px;
        }
        
        .sender-name {
            font-size: 13px;
            font-weight: 700;
            color: #222;
        }
        
        .sender-title {
            font-size: 11px;
            color: #666;
            margin-top: 2px;
        }

        /* Contact Footer */
        .contact-footer {
            margin-top: 30px;
            display: flex;
            justify-content: center;
            gap: 20px;
            page-break-inside: avoid;
        }
        
        .contact-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 10px;
            font-weight: 500;
            color: #555;
        }
        
        .contact-icon {
            width: 20px;
            height: 20px;
            background: #1a5632;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 10px;
        }
    </style>
</head>
<body>
    <div class="a4-container">
        <!-- Exact Top Left Geometric Shape -->
        <svg class="shape-top-left" viewBox="0 0 400 350" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,0 L400,0 C320,160 160,260 0,350 Z" fill="#ebf2ee" />
            <path d="M0,0 L320,0 C250,130 120,220 0,280 Z" fill="#b0cebc" />
            <path d="M0,0 L220,0 C170,90 80,160 0,200 Z" fill="#1a5632" />
        </svg>

        <!-- Exact Bottom Right Geometric Shape -->
        <svg class="shape-bottom-right" viewBox="0 0 500 450" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M500,450 L0,450 C80,250 250,120 500,0 Z" fill="#ebf2ee" />
            <path d="M500,450 L120,450 C180,280 320,180 500,80 Z" fill="#b0cebc" />
            <path d="M500,450 L250,450 C290,340 380,250 500,180 Z" fill="#1a5632" />
        </svg>

        <!-- Document Content -->
        <div class="content-layer">
            
            <div class="header-area">
                <div class="company-name">{{company_name}}</div>
                <div class="doc-title-wrapper">
                    <div class="doc-title">JOB OFFER LETTER</div>
                </div>
            </div>

            <div class="info-block">
                <div class="info-row">
                    <div class="info-label">Date:</div>
                    <div class="info-value">{{document_date}}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">To:</div>
                    <div class="info-value">{{candidate_name}}</div>
                </div>
                {{#if candidate_address}}
                <div class="info-row">
                    <div class="info-label">Address:</div>
                    <div class="info-value">{{{candidate_address}}}</div>
                </div>
                {{/if}}
                <div class="info-row">
                    <div class="info-label">Subject:</div>
                    <div class="info-value">Offer of Employment — {{position}}</div>
                </div>
            </div>

            <div class="body-text">
                <p>Dear <strong>{{candidate_name}}</strong>,</p>
                
                <p>We are delighted to extend this offer of employment for the position of <strong>{{position}}</strong> with <strong>{{company_name}}</strong>. Having reviewed your background and discussed your career aspirations, we are confident that your expertise and vision will be a vital addition to our team.</p>

                <p>In this capacity, you will report directly to <strong>{{reporting_to}}</strong> and your primary place of work will be based in <strong>{{work_location}}</strong>. We are excited about the prospect of you joining us and sincerely hope you will commence your professional journey with our company on <strong>{{start_date}}</strong>.</p>

                <p>As per the details elaborated during our discussions, your starting compensation package will consist of an annual CTC of <strong>{{#if salary_in_words}}₹{{salary}} ({{salary_in_words}}){{else}}₹{{salary}} per annum{{/if}}</strong>. In addition to this, you will be eligible for health insurance, paid leave, and comprehensive employee benefits in accordance with the standard policies of the company.</p>

                <p>We firmly believe that this represents a foundational step towards a mutually beneficial and highly rewarding association. We look forward to proudly welcoming you aboard and collaborating to achieve outstanding success.</p>
                
                <p>Please kindly signify your acceptance of this offer by signing and sharing a copy of this document with our Human Resources department.</p>
            </div>

            <div class="signature-area">
                <div class="signature-block">
                    <div class="sig-label">FOR &amp; ON BEHALF OF {{company_name}}</div>
                    <div class="sig-line">
                        <div class="sender-name">{{signatory_name}}</div>
                        <div class="sender-title">{{signatory_designation}}</div>
                    </div>
                </div>
                
                <div class="signature-block">
                    <div class="sig-label">ACCEPTANCE BY CANDIDATE</div>
                    <div class="sig-line">
                        <div class="sender-name">{{candidate_name}}</div>
                        <div class="sender-title">Date: _________________</div>
                    </div>
                </div>
            </div>

            <div class="contact-footer">
                {{#if company_phone}}
                <div class="contact-item">
                    <div class="contact-icon">✆</div>
                    <div>{{company_phone}}</div>
                </div>
                {{/if}}
                {{#if company_website}}
                <div class="contact-item">
                    <div class="contact-icon">🌐</div>
                    <div>{{company_website}}</div>
                </div>
                {{/if}}
                {{#if company_address}}
                <div class="contact-item">
                    <div class="contact-icon">✉</div>
                    <div>{{{company_address}}}</div>
                </div>
                {{/if}}
            </div>

        </div>
    </div>
</body>
</html>