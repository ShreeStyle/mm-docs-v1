<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Proposal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            color: #1f2937;
            background: white;
            font-size: 14px;
            line-height: 1.6;
        }

        /* Colors & Theme */
        :root {
            --brand-green: #059669;
            --brand-dark: #111827;
            --brand-gray: #f3f4f6;
            --text-main: #374151;
            --text-light: #6b7280;
        }

        h1, h2, h3, h4, h5, h6 {
            color: var(--brand-dark);
            font-weight: 700;
        }

        .page {
            width: 794px; /* A4 width approx at 96dpi */
            min-height: 1123px;
            padding: 60px;
            margin: 0 auto;
            background: white;
            position: relative;
            page-break-after: always;
            box-sizing: border-box;
        }

        /* Left Green Bar Accent for Pages */
        .page-accent {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 15px;
            background-color: var(--brand-green);
        }

        /* Cover Page */
        .cover-page {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 1000px;
        }

        .cover-header {
            margin-bottom: auto;
        }

        .cover-title {
            font-size: 56px;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 20px;
            color: var(--brand-dark);
        }
        
        .cover-subtitle {
            font-size: 24px;
            color: var(--brand-green);
            font-weight: 600;
            margin-bottom: 40px;
        }

        .cover-brand {
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--brand-dark);
            margin-bottom: 10px;
            font-weight: 700;
        }
        
        .cover-date {
            font-size: 16px;
            color: var(--text-light);
            margin-bottom: 100px;
        }

        .prepared-section {
            display: flex;
            justify-content: space-between;
            margin-top: auto;
            border-top: 2px solid var(--brand-dark);
            padding-top: 30px;
        }

        .prepared-block {
            width: 45%;
        }

        .prepared-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--brand-green);
            font-weight: 700;
            margin-bottom: 10px;
        }

        .prepared-name {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .prepared-details {
            font-size: 14px;
            color: var(--text-light);
            white-space: pre-line;
        }

        /* Inner Pages */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e5e7eb;
        }

        .page-brand {
            font-size: 14px;
            font-weight: 700;
            line-height: 1.2;
        }
        
        .page-brand span {
            display: block;
            color: var(--brand-green);
        }

        .page-title {
            font-size: 32px;
            font-weight: 800;
            color: var(--brand-dark);
            position: relative;
        }
        
        .section-number {
            font-size: 60px;
            font-weight: 800;
            color: rgba(5, 150, 105, 0.1);
            position: absolute;
            right: 0;
            top: -20px;
            line-height: 1;
        }

        /* Content Formatting */
        .content-text {
            font-size: 16px;
            color: var(--text-main);
            line-height: 1.8;
            margin-bottom: 20px;
        }

        .content-highlight {
            font-size: 20px;
            font-weight: 600;
            color: var(--brand-green);
            line-height: 1.5;
            margin: 40px 0;
            padding-left: 20px;
            border-left: 4px solid var(--brand-dark);
        }

        /* Grid Layouts */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-top: 30px;
        }

        .card {
            background: var(--brand-gray);
            padding: 30px;
            border-radius: 8px;
        }

        .card-number {
            font-size: 30px;
            font-weight: 800;
            color: var(--brand-green);
            margin-bottom: 15px;
        }

        .card-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 15px;
        }

        /* Timeline */
        .timeline {
            margin-top: 40px;
        }

        .timeline-item {
            display: flex;
            margin-bottom: 30px;
            position: relative;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: 25px;
            top: 50px;
            bottom: -30px;
            width: 2px;
            background: #e5e7eb;
        }

        .timeline-item:last-child::before {
            display: none;
        }

        .timeline-dot {
            width: 50px;
            height: 50px;
            background: var(--brand-dark);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 20px;
            margin-right: 30px;
            flex-shrink: 0;
            z-index: 1;
        }

        .timeline-content {
            padding-top: 10px;
        }

        .timeline-phase {
            font-size: 14px;
            color: var(--brand-green);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .timeline-desc {
            font-size: 18px;
            font-weight: 700;
            color: var(--brand-dark);
        }

        /* Budget Table */
        .budget-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
        }

        .budget-table th {
            text-align: left;
            padding: 15px 20px;
            background: var(--brand-dark);
            color: white;
            font-weight: 600;
        }

        .budget-table td {
            padding: 15px 20px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 16px;
        }

        .budget-table tr:last-child {
            font-weight: 700;
            font-size: 20px;
            background: var(--brand-gray);
        }

        .budget-table td:last-child,
        .budget-table th:last-child {
            text-align: right;
        }

        /* Footer */
        .contact-footer {
            margin-top: 80px;
            padding-top: 40px;
            border-top: 2px solid var(--brand-dark);
            display: flex;
            justify-content: space-between;
        }

        .contact-title {
            font-size: 32px;
            font-weight: 800;
            color: var(--brand-dark);
        }

        .contact-info {
            text-align: right;
        }

        .contact-info p {
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 5px;
            color: var(--text-main);
        }

        .contact-info p.phone {
            font-size: 20px;
            font-weight: 700;
            color: var(--brand-green);
            margin-bottom: 10px;
        }

        /* Helper classes */
        .bullet-list {
            padding-left: 20px;
            margin-top: 20px;
        }

        .bullet-list li {
            font-size: 16px;
            margin-bottom: 10px;
            line-height: 1.6;
            color: var(--text-main);
        }
        
        .white-space-pre {
            white-space: pre-wrap;
        }

    </style>
</head>

<body>

    <!-- Cover Page -->
    <div class="page">
        <div class="page-accent"></div>
        <div class="cover-page">
            <div class="cover-header">
                <div class="cover-brand">
                    {{#if company_name}}{{company_name}}{{else}}Company Name{{/if}}
                </div>
                <div class="cover-date">
                    {{#if proposal_date}}{{proposal_date}}{{else}}{{document_date}}{{/if}}
                </div>
                
                <h1 class="cover-title">Project<br>Proposal</h1>
                <div class="cover-subtitle">
                    {{#if project_title}}{{project_title}}{{else}}Project Title{{/if}}
                </div>
            </div>

            <div class="prepared-section">
                <div class="prepared-block">
                    <div class="prepared-label">Prepared By :</div>
                    <div class="prepared-name">{{#if company_name}}{{company_name}}{{else}}Company Name{{/if}}</div>
                    <div class="prepared-details">
                        {{#if company_address}}{{company_address}}{{/if}}
                        {{#if company_email}}<br>{{company_email}}{{/if}}
                        {{#if company_phone}}<br>{{company_phone}}{{/if}}
                    </div>
                </div>
                <div class="prepared-block">
                    <div class="prepared-label">Prepared For :</div>
                    <div class="prepared-name">{{#if client_name}}{{client_name}}{{else}}Client Name{{/if}}</div>
                    <div class="prepared-details">
                        {{#if client_company}}{{client_company}}{{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Executive Summary Page -->
    <div class="page">
        <div class="page-header">
            <div class="page-brand">
                {{#if company_name}}{{company_name}}{{else}}Company Name{{/if}}
                <span>{{#if proposal_date}}{{proposal_date}}{{else}}{{document_date}}{{/if}}</span>
            </div>
            <div class="page-title">
                Summary
                <div class="section-number">01</div>
            </div>
        </div>

        <div class="content-highlight white-space-pre">
            {{#if project_description}}{{project_description}}{{else}}Provide a comprehensive summary of the project goals, vision, and strategic approach.{{/if}}
        </div>

        <h3 style="margin-top: 40px; margin-bottom: 20px; font-size: 24px;">Project Objectives</h3>
        <div class="content-text white-space-pre">{{#if problem_statement}}{{problem_statement}}{{else}}Define specific goals and objectives.{{/if}}</div>
    </div>

    <!-- Methodology & Scope Page -->
    <div class="page">
        <div class="page-header">
            <div class="page-brand">
                {{#if company_name}}{{company_name}}{{else}}Company Name{{/if}}
                <span>{{#if proposal_date}}{{proposal_date}}{{else}}{{document_date}}{{/if}}</span>
            </div>
            <div class="page-title">
                Methodology & Scope
                <div class="section-number">02</div>
            </div>
        </div>

        <div class="grid-2">
            <div class="card">
                <div class="card-title">Proposed Solution / Methodology</div>
                <div class="content-text white-space-pre">{{#if proposed_solution}}{{proposed_solution}}{{else}}Detailed methodology.{{/if}}</div>
            </div>
            <div class="card" style="background: var(--brand-dark); color: white;">
                <div class="card-title" style="color: white;">Scope (Inclusions)</div>
                <div class="content-text white-space-pre" style="color: #e5e7eb;">{{#if target_audience}}{{target_audience}}{{else}}List project inclusions.{{/if}}</div>
            </div>
        </div>

        {{#if key_features}}
        <h3 style="margin-top: 40px; margin-bottom: 20px; font-size: 20px;">Scope Limitations & Exclusions</h3>
        <div class="content-text white-space-pre">{{key_features}}</div>
        {{/if}}
        
        {{#if deliverables}}
        <h3 style="margin-top: 40px; margin-bottom: 20px; font-size: 20px;">Expected Outcomes / Deliverables</h3>
        <div class="content-text white-space-pre">{{deliverables}}</div>
        {{/if}}
    </div>

    <!-- Timeline & Logistics Page -->
    <div class="page">
        <div class="page-header">
            <div class="page-brand">
                {{#if company_name}}{{company_name}}{{else}}Company Name{{/if}}
                <span>{{#if proposal_date}}{{proposal_date}}{{else}}{{document_date}}{{/if}}</span>
            </div>
            <div class="page-title">
                Timeline & Budget
                <div class="section-number">03</div>
            </div>
        </div>

        <h3 style="margin-bottom: 20px; font-size: 24px;">Project Timeline</h3>
        <div class="content-text white-space-pre">{{#if project_timeline}}{{project_timeline}}{{else}}Detailed timeline.{{/if}}</div>

        <h3 style="margin-top: 50px; margin-bottom: 20px; font-size: 24px;">Estimated Budget</h3>
        <table class="budget-table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th>Estimated Cost</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Project Budget Estimate (Total)</td>
                    <td>₹{{#if project_budget}}{{project_budget}}{{else}}0.00{{/if}}</td>
                </tr>
            </tbody>
        </table>

        {{#if team_members}}
        <h3 style="margin-top: 50px; margin-bottom: 20px; font-size: 24px;">Key Stakeholders & Team</h3>
        <div class="content-text white-space-pre">{{team_members}}</div>
        {{/if}}

        {{#if special_notes}}
        <h3 style="margin-top: 40px; margin-bottom: 20px; font-size: 20px;">Risk Assessment & Notes</h3>
        <div class="content-text white-space-pre">{{special_notes}}</div>
        {{/if}}

        <div class="contact-footer">
            <div class="contact-title">
                Let's Work<br>Together
            </div>
            <div class="contact-info">
                {{#if company_phone}}<p class="phone">{{company_phone}}</p>{{/if}}
                <p>Contact Us</p>
                {{#if company_email}}<p>{{company_email}}</p>{{/if}}
                {{#if company_website}}<p>{{company_website}}</p>{{/if}}
            </div>
        </div>
    </div>

</body>
</html>