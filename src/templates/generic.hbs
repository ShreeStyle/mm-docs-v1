<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    {{{brandCSS}}}
    body {
      font-family: var(--font-primary), sans-serif;
      color: #333;
      padding: 40px;
      line-height: 1.6;
    }
    h1 { color: var(--primary-color); margin-bottom: 10px; }
    h2 { color: var(--secondary-color); border-bottom: 2px solid var(--accent-color); padding-bottom: 8px; }
    h3 { color: var(--primary-color); margin-top: 24px; }
    .content { margin-top: 30px; }
  </style>
</head>
<body>
  {{{brandHeader}}}
  
  <h1>{{title}}</h1>
  <p class="highlight"><strong>Date:</strong> {{generatedDate}}</p>
  
  <div class="content">
    <h3>Summary</h3>
    <p>{{content.summary}}</p>
    <p>{{content.details}}</p>
  </div>

  {{{footerHTML}}}
</body>
</html>
