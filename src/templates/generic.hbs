<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    {{{brandCSS}}}
    body {
      font-family: var(--font-primary), sans-serif;
      color: #333;
      padding: 40px;
      line-height: 1.6;
    }
    h1 { color: var(--primary-color); margin-bottom: 10px; }
    h2 { color: var(--secondary-color); border-bottom: 2px solid var(--accent-color); padding-bottom: 8px; }
    h3 { color: var(--primary-color); margin-top: 24px; }
    .content { margin-top: 30px; }
  </style>
</head>
<body>
  {{{brandHeader}}}
  
  <h1>{{title}}</h1>
  <p class="highlight"><strong>Date:</strong> {{generatedDate}}</p>
  
  <div class="content">
    {{#if content.summary}}
      <h3>Overview</h3>
      <p>{{content.summary}}</p>
    {{/if}}

    {{#if sections}}
      <div class="dynamic-sections">
        {{#each sections}}
          <div class="section-item">
            <h3>{{this.heading}}</h3>
            <p>{{this.content}}</p>
          </div>
        {{/each}}
      </div>
    {{/if}}

    {{#if content.details}}
      <p>{{content.details}}</p>
    {{/if}}
  </div>

  {{{footerHTML}}}
</body>
</html>
