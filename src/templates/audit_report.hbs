<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audit Report</title>
    <style>
        body {
            font-family: 'Times New Roman', serif;
            line-height: 1.6;
            color: #000;
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            background: white;
            font-size: 12pt;
        }
        .header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 2px solid #000;
            padding-bottom: 20px;
        }
        .company-name {
            font-size: 20pt;
            font-weight: bold;
            color: #000;
            margin-bottom: 8px;
            text-transform: uppercase;
        }
        .document-title {
            font-size: 18pt;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 30px 0;
            text-align: center;
            color: #000;
            text-decoration: underline;
        }
        .content {
            margin-bottom: 30px;
            text-align: justify;
        }
        .content p {
            margin-bottom: 15px;
        }
        .details-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            border: 2px solid #000;
        }
        .details-table th,
        .details-table td {
            border: 1px solid #000;
            padding: 12px;
            text-align: left;
            font-size: 11pt;
        }
        .details-table th {
            background-color: #f5f5f5;
            font-weight: bold;
        }
        .findings-section {
            margin: 25px 0;
            border: 1px solid #000;
            padding: 20px;
        }
        .signature-section {
            margin-top: 50px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="company-name">{{companyName}}</div>
        <div>{{companyAddress}}</div>
    </div>

    <div class="document-title">Audit Report</div>

    <div class="content">
        <table class="details-table">
            <tr>
                <th>Audit Period</th>
                <td>{{auditPeriod}}</td>
            </tr>
            <tr>
                <th>Audit Type</th>
                <td>{{auditType}}</td>
            </tr>
            <tr>
                <th>Auditor</th>
                <td>{{auditorName}}</td>
            </tr>
            <tr>
                <th>Audit Date</th>
                <td>{{auditDate}}</td>
            </tr>
        </table>

        <div class="findings-section">
            <h3 style="text-decoration: underline; text-align: center;">Key Findings</h3>
            <p>{{findings}}</p>
        </div>
    </div>

    <div class="signature-section">
        <p><strong>{{auditorName}}</strong></p>
        <p>Certified Auditor</p>
        <p>Date: {{auditDate}}</p>
    </div>
</body>
</html>