<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Outfit', sans-serif;
            color: #2D3748;
            line-height: 1.4;
            margin: 0;
            padding: 0;
            background: #fff;
            font-size: 9px;
        }

        .page-container {
            padding: 40px;
        }

        .main-header {
            background: linear-gradient(135deg, #1A202C 0%, #2D3748 100%);
            color: white;
            padding: 30px 40px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-content h1 {
            font-size: 28px;
            margin: 0;
            letter-spacing: 2px;
            font-weight: 700;
            color: #F6AD55;
        }

        .header-content p {
            margin: 5px 0 0 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .company-info {
            text-align: right;
        }

        .company-info h2 {
            font-size: 18px;
            margin: 0;
            color: #fff;
        }

        .company-info p {
            margin: 2px 0;
            font-size: 11px;
            color: #CBD5E0;
        }

        .summary-ribbon {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin: 0 40px 30px 40px;
        }

        .summary-card {
            background: #F7FAFC;
            border: 1px solid #E2E8F0;
            padding: 12px;
            border-radius: 8px;
            border-top: 3px solid #ED8936;
        }

        .summary-card .label {
            font-size: 8px;
            color: #718096;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .summary-card .value {
            font-size: 14px;
            font-weight: 700;
            color: #2D3748;
        }

        .section-container {
            margin-bottom: 35px;
        }

        .section-title {
            font-size: 14px;
            font-weight: 700;
            color: #2D3748;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #E2E8F0;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 0;
            table-layout: fixed;
            border: 1px solid #E2E8F0;
            border-radius: 8px;
            overflow: hidden;
        }

        th {
            background-color: #F8FAFC;
            color: #4A5568;
            font-weight: 700;
            font-size: 8px;
            text-transform: uppercase;
            padding: 10px 8px;
            border-bottom: 2px solid #E2E8F0;
            text-align: center;
        }

        td {
            padding: 8px;
            border-bottom: 1px solid #EDF2F7;
            color: #4A5568;
            word-wrap: break-word;
            vertical-align: middle;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:nth-child(even) {
            background-color: #FBFDFF;
        }

        .text-right { text-align: right; }
        .font-bold { font-weight: 700; }
        .text-orange { color: #DD6B20; }
        .text-blue { color: #2C5282; }

        .sub-header {
            background-color: #EDF2F7;
            font-size: 7px;
            color: #718096;
        }

        .footer {
            margin-top: 60px;
            display: flex;
            justify-content: space-between;
            padding: 0 40px 40px 40px;
        }

        .footer-left p {
            margin: 2px 0;
            color: #718096;
        }

        .signature-box {
            text-align: right;
            width: 200px;
        }

        .signature-line {
            height: 1px;
            background: #2D3748;
            margin: 50px 0 10px 0;
        }

        .signature-box h3 {
            margin: 0;
            font-size: 11px;
            text-transform: uppercase;
        }

        @media print {
            .page-break {
                page-break-before: always;
            }
        }
    </style>
</head>
<body>
    <div class="main-header">
        <div class="header-content">
            <h1>GSTR-1</h1>
            <p>Filing Period: <strong>{{dateRange}}</strong></p>
        </div>
        <div class="company-info">
            <h2>{{companyName}}</h2>
            <p>GSTIN: {{gstNo}}{{#if mobile}} | Mob: {{mobile}}{{/if}}</p>
        </div>
    </div>

    <div class="summary-ribbon">
        <div class="summary-card">
            <div class="label">Taxable Turnover</div>
            <div class="value">₹{{numberFormat summary.totalTaxableValue}}</div>
        </div>
        <div class="summary-card" style="border-top-color: #4299E1;">
            <div class="label">Tax Credit (Returns)</div>
            <div class="value">₹{{numberFormat summary.returnTax}}</div>
        </div>
        <div class="summary-card" style="border-top-color: #48BB78;">
            <div class="label">Central/State Tax</div>
            <div class="value">₹{{numberFormat (add summary.totalCGST summary.totalSGST)}}</div>
        </div>
        <div class="summary-card" style="border-top-color: #ED8936;">
            <div class="label">Net GST Payable / Refund</div>
            <div class="value" style="color: #DD6B20;">₹{{numberFormat summary.netPayable}}</div>
        </div>
    </div>

    <div class="page-container">

    <div class="page-container">
        <div class="section-container">
            <div class="section-title">Details of Outward Supplies (Sales)</div>
            <table>
                <thead>
                    <tr>
                        <th rowspan="2" style="width: 12%; text-align: left;">GSTIN</th>
                        <th rowspan="2" style="width: 15%; text-align: left;">Customer Name</th>
                        <th colspan="2" class="sub-header">Place of Supply</th>
                        <th colspan="3" class="sub-header">Invoice Details</th>
                        <th rowspan="2" style="width: 5%;">Tax %</th>
                        <th rowspan="2" style="width: 8%; text-align: right;">Taxable</th>
                        <th colspan="4" class="sub-header">Amount of Tax</th>
                        <th rowspan="2" style="width: 7%; text-align: right;">Total Tax</th>
                    </tr>
                    <tr>
                        <th class="sub-header">Code</th>
                        <th class="sub-header">State</th>
                        <th class="sub-header">No.</th>
                        <th class="sub-header">Date</th>
                        <th class="sub-header">Value</th>
                        <th class="sub-header">CGST</th>
                        <th class="sub-header">SGST</th>
                        <th class="sub-header">IGST</th>
                        <th class="sub-header">CESS</th>
                    </tr>
                </thead>
                <tbody>
                    {{#if sales}}
                        {{#each sales}}
                        <tr>
                            <td class="font-bold">{{gstin}}</td>
                            <td>{{customerName}}</td>
                            <td style="text-align: center;">{{placeOfSupply.code}}</td>
                            <td>{{placeOfSupply.name}}</td>
                            <td>{{invoiceDetails.no}}</td>
                            <td>{{invoiceDetails.date}}</td>
                            <td class="text-right">{{numberFormat invoiceDetails.value}}</td>
                            <td class="text-right">{{totalTaxPct}}%</td>
                            <td class="text-right font-bold">{{numberFormat taxableValue}}</td>
                            <td class="text-right">{{numberFormat taxAmount.central}}</td>
                            <td class="text-right">{{numberFormat taxAmount.state}}</td>
                            <td class="text-right text-blue">{{numberFormat taxAmount.integrated}}</td>
                            <td class="text-right">{{numberFormat taxAmount.cess}}</td>
                            <td class="text-right font-bold text-orange">₹{{numberFormat totalTax}}</td>
                        </tr>
                        {{/each}}
                    {{else}}
                        <tr><td colspan="14" style="text-align: center; padding: 40px; color: #A0AEC0;">No sales records found</td></tr>
                    {{/if}}
                </tbody>
            </table>
        </div>

        <div class="section-container">
            <div class="section-title">Sales Returns & Credit Notes</div>
            <table>
                <thead>
                    <tr>
                        <th rowspan="2" style="width: 12%; text-align: left;">GSTIN</th>
                        <th rowspan="2" style="width: 15%; text-align: left;">Customer</th>
                        <th colspan="2" class="sub-header">POS</th>
                        <th colspan="3" class="sub-header">Note Details</th>
                        <th rowspan="2" style="width: 5%;">Tax %</th>
                        <th rowspan="2" style="width: 8%; text-align: right;">Value</th>
                        <th colspan="4" class="sub-header">Tax Adjustment</th>
                        <th rowspan="2" style="width: 7%; text-align: right;">Total Credit</th>
                    </tr>
                    <tr>
                        <th class="sub-header">Code</th>
                        <th class="sub-header">State</th>
                        <th class="sub-header">No.</th>
                        <th class="sub-header">Date</th>
                        <th class="sub-header">Value</th>
                        <th class="sub-header">CGST</th>
                        <th class="sub-header">SGST</th>
                        <th class="sub-header">IGST</th>
                        <th class="sub-header">CESS</th>
                    </tr>
                </thead>
                <tbody>
                    {{#if salesReturn}}
                        {{#each salesReturn}}
                        <tr>
                            <td class="font-bold">{{gstin}}</td>
                            <td>{{customerName}}</td>
                            <td style="text-align: center;">{{placeOfSupply.code}}</td>
                            <td>{{placeOfSupply.name}}</td>
                            <td>{{invoiceDetails.no}}</td>
                            <td>{{invoiceDetails.date}}</td>
                            <td class="text-right">{{numberFormat invoiceDetails.value}}</td>
                            <td class="text-right">{{totalTaxPct}}%</td>
                            <td class="text-right font-bold">{{numberFormat taxableValue}}</td>
                            <td class="text-right">{{numberFormat taxAmount.central}}</td>
                            <td class="text-right">{{numberFormat taxAmount.state}}</td>
                            <td class="text-right">{{numberFormat taxAmount.integrated}}</td>
                            <td class="text-right">{{numberFormat taxAmount.cess}}</td>
                            <td class="text-right font-bold" style="color: #4299E1;">₹{{numberFormat totalTax}}</td>
                        </tr>
                        {{/each}}
                    {{else}}
                        <tr><td colspan="14" style="text-align: center; padding: 40px; color: #A0AEC0;">No returns found</td></tr>
                    {{/if}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="footer">
        <div class="footer-left">
            <p>Certified Signatory:</p>
            <div style="height: 40px; margin: 10px 0;">
                 {{#if signatorySignature}}
                    <img src="{{signatorySignature}}" style="max-height: 40px;" />
                {{/if}}
            </div>
            <p class="font-bold" style="color: #1A202C; font-size: 11px;">{{authorizedSignatory.name}}</p>
            <p style="font-size: 9px;">{{authorizedSignatory.designation}}</p>
            <p style="font-size: 7px; margin-top: 5px; color: #A0AEC0;">Generated on {{generatedDate}} | GSTR-1 Summary Report</p>
        </div>
        <div class="signature-box">
             <div class="signature-line"></div>
             <h3>Authorized Stamp / Seal</h3>
        </div>
    </div>
</body>
</html>
