<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{content.title}}</title>
    <style>
        {{{brandCSS}}}
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: var(--font-primary, 'Times New Roman', serif);
            line-height: 1.6;
            color: #2d3748;
            background: #ffffff;
            font-size: 14px;
        }
        
        .document-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            min-height: 100vh;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 3px solid var(--primary-color, #1e40af);
        }
        
        .document-title {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color, #1e40af);
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .parties-section {
            background: #f8fafc;
            padding: 24px;
            border-radius: 12px;
            border-left: 4px solid var(--primary-color, #1e40af);
            margin: 32px 0;
        }
        
        .party-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-top: 16px;
        }
        
        .party {
            text-align: center;
            padding: 16px;
            background: white;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
        }
        
        .party-label {
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        
        .party-name {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary-color, #1e40af);
        }
        
        .section {
            margin: 32px 0;
        }
        
        .section-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--primary-color, #1e40af);
            margin-bottom: 16px;
            padding-bottom: 8px;
            border-bottom: 2px solid #e2e8f0;
            text-transform: uppercase;
        }
        
        .clause-list {
            list-style: none;
            padding: 0;
            counter-reset: clause-counter;
        }
        
        .clause-list li {
            padding: 12px 0;
            padding-left: 40px;
            position: relative;
            counter-increment: clause-counter;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .clause-list li:before {
            content: counter(clause-counter, decimal) ".";
            position: absolute;
            left: 0;
            font-weight: bold;
            color: var(--primary-color, #1e40af);
        }
        
        .signature-section {
            margin-top: 48px;
            padding-top: 32px;
            border-top: 2px solid #e2e8f0;
        }
        
        .signature-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
            margin-top: 32px;
        }
        
        .signature-box {
            text-align: center;
            padding: 24px;
            border: 2px solid var(--primary-color, #1e40af);
            border-radius: 12px;
        }
        
        .legal-notice {
            background: #fef3c7;
            border: 1px solid #fde68a;
            padding: 16px;
            border-radius: 8px;
            margin: 24px 0;
            font-size: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="document-container">
        <div class="header">
            <div class="document-title">{{content.title}}</div>
            <div style="font-size: 14px; color: #64748b;">Effective Date: {{content.effectiveDate}}</div>
        </div>

        <div class="parties-section">
            <div style="text-align: center; font-size: 16px; font-weight: 600; margin-bottom: 16px;">
                Agreement Between
            </div>
            <div class="party-info">
                <div class="party">
                    <div class="party-label">Disclosing Party</div>
                    <div class="party-name">{{content.disclosingParty}}</div>
                </div>
                <div class="party">
                    <div class="party-label">Receiving Party</div>
                    <div class="party-name">{{content.receivingParty}}</div>
                </div>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Purpose</div>
            <p>{{content.purpose}}</p>
        </div>

        <div class="section">
            <div class="section-title">Confidential Information</div>
            <ul class="clause-list">
                {{#each content.confidentialInformation}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>

        <div class="section">
            <div class="section-title">Obligations of Receiving Party</div>
            <ul class="clause-list">
                {{#each content.obligations}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>

        <div class="section">
            <div class="section-title">Exceptions</div>
            <ul class="clause-list">
                {{#each content.exceptions}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>

        <div class="section">
            <div class="section-title">Duration & Remedies</div>
            <p><strong>Duration:</strong> {{content.duration}}</p>
            <br>
            <p><strong>Remedies:</strong> {{content.remedies}}</p>
        </div>

        <div class="legal-notice">
            <strong>Governing Law:</strong> {{content.governingLaw}}
        </div>

        <div class="signature-section">
            <div style="text-align: center; font-size: 16px; font-weight: 600; margin-bottom: 24px;">
                Signatures
            </div>
            <div class="signature-grid">
                <div class="signature-box">
                    <p><strong>{{content.signatures.disclosingParty}}</strong></p>
                    <br><br>
                    <p>_________________________</p>
                    <p>Signature</p>
                    <br>
                    <p>Date: _________________</p>
                </div>
                <div class="signature-box">
                    <p><strong>{{content.signatures.receivingParty}}</strong></p>
                    <br><br>
                    <p>_________________________</p>
                    <p>Signature</p>
                    <br>
                    <p>Date: _________________</p>
                </div>
            </div>
        </div>

        <div style="margin-top: 32px; text-align: center; font-size: 12px; color: #64748b;">
            <p>This document was generated on {{content.date}}</p>
        </div>
    </div>
</body>
</html>