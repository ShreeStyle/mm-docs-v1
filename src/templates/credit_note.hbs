<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credit Note</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            line-height: 1.5;
            color: #1f2937;
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            background: white;
            font-size: 13px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding-bottom: 24px;
            margin-bottom: 28px;
            border-bottom: 1px solid #e5e7eb;
        }

        .company-name {
            font-size: 22px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 6px;
        }

        .company-detail {
            font-size: 12px;
            color: #4b5563;
            line-height: 1.5;
        }

        .company-detail strong {
            color: #111827;
        }

        .doc-badge {
            text-align: right;
        }

        .doc-title {
            font-size: 28px;
            font-weight: 800;
            color: #fecaca;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .type-badge {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 9999px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            background: #fef2f2;
            color: #dc2626;
            margin-top: 8px;
        }

        .meta-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 12px;
            margin-bottom: 24px;
        }

        .meta-item {
            background: #f9fafb;
            border-radius: 6px;
            padding: 10px 14px;
        }

        .meta-item .label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #6b7280;
            font-weight: 600;
        }

        .meta-item .value {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
            margin-top: 2px;
        }

        .parties-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 24px;
        }

        .party-card {
            background: #f9fafb;
            border-radius: 8px;
            padding: 16px;
        }

        .party-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #6b7280;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .party-name {
            font-size: 15px;
            font-weight: 600;
            color: #111827;
            margin-bottom: 4px;
        }

        .party-detail {
            font-size: 12px;
            color: #4b5563;
            line-height: 1.5;
        }

        .reason-section {
            background: #fef2f2;
            border-radius: 8px;
            padding: 16px 20px;
            margin-bottom: 24px;
            border-left: 4px solid #ef4444;
        }

        .reason-label {
            font-size: 11px;
            font-weight: 600;
            color: #991b1b;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 4px;
        }

        .reason-text {
            font-size: 14px;
            color: #7f1d1d;
            line-height: 1.6;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }

        .items-table thead th {
            background: #f9fafb;
            text-align: left;
            padding: 10px 14px;
            font-size: 11px;
            font-weight: 600;
            color: #6b7280;
            border-bottom: 1px solid #e5e7eb;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .items-table thead th:nth-child(n+3) {
            text-align: right;
        }

        .items-table tbody td {
            padding: 10px 14px;
            font-size: 13px;
            color: #111827;
            border-bottom: 1px solid #f3f4f6;
        }

        .items-table tbody td:nth-child(n+3) {
            text-align: right;
            font-weight: 500;
        }

        .items-table tbody td:first-child {
            font-size: 12px;
            color: #6b7280;
            text-align: center;
            width: 36px;
        }

        .totals-section {
            display: flex;
            justify-content: flex-end;
            margin: 20px 0;
        }

        .totals-table {
            width: 300px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 16px;
            font-size: 13px;
            color: #374151;
            border-bottom: 1px solid #f3f4f6;
        }

        .total-row.grand {
            background: #dc2626;
            color: white;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 16px;
            font-weight: 700;
            border-bottom: none;
            margin-top: 4px;
        }

        .note-section {
            background: #f9fafb;
            border-radius: 8px;
            padding: 16px 20px;
            margin: 24px 0;
            font-size: 12px;
            color: #6b7280;
            line-height: 1.6;
        }

        .note-section strong {
            color: #111827;
        }

        .signature-section {
            margin-top: 40px;
            display: flex;
            justify-content: flex-end;
        }

        .sig-block {
            text-align: right;
        }

        .sig-label {
            font-size: 11px;
            color: #6b7280;
            margin-bottom: 40px;
        }

        .sig-line {
            border-top: 1px solid #d1d5db;
            padding-top: 6px;
            min-width: 220px;
        }

        .sig-name {
            font-size: 13px;
            font-weight: 600;
            color: #111827;
        }

        .sig-role {
            font-size: 11px;
            color: #6b7280;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
            color: #9ca3af;
            font-size: 11px;
        }
    </style>
</head>

<body>
    <div class="header">
        <div>
            <div class="company-name">{{companyName}}</div>
            <div class="company-detail">{{{companyAddress}}}</div>
            {{#if gstNumber}}<div class="company-detail"><strong>GSTIN:</strong> {{gstNumber}}</div>{{/if}}
        </div>
        <div class="doc-badge">
            <div class="doc-title">CREDIT NOTE</div>
            <div class="type-badge">Adjustment</div>
        </div>
    </div>

    <div class="meta-row">
        <div class="meta-item">
            <div class="label">Credit Note No.</div>
            <div class="value">{{creditNoteNumber}}</div>
        </div>
        <div class="meta-item">
            <div class="label">Date</div>
            <div class="value">{{creditNoteDate}}</div>
        </div>
        <div class="meta-item">
            <div class="label">Original Invoice</div>
            <div class="value">{{originalInvoiceNumber}}</div>
        </div>
    </div>

    <div class="parties-grid">
        <div class="party-card">
            <div class="party-label">Issued By</div>
            <div class="party-name">{{companyName}}</div>
            <div class="party-detail">{{{companyAddress}}}</div>
            {{#if gstNumber}}<div class="party-detail"><strong>GST:</strong> {{gstNumber}}</div>{{/if}}
        </div>
        <div class="party-card">
            <div class="party-label">Issued To</div>
            <div class="party-name">{{clientName}}</div>
            <div class="party-detail">{{{clientAddress}}}</div>
            {{#if clientGST}}<div class="party-detail"><strong>GST:</strong> {{clientGST}}</div>{{/if}}
        </div>
    </div>

    <div class="reason-section">
        <div class="reason-label">Reason for Credit Note</div>
        <div class="reason-text">{{{reason}}}</div>
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Description</th>
                <th>Qty</th>
                <th>Rate</th>
                <th>Amount</th>
            </tr>
        </thead>
        <tbody>
            {{#each items}}
            <tr>
                <td>{{@index}}</td>
                <td>{{this.description}}</td>
                <td style="text-align:right;">{{this.quantity}}</td>
                <td>₹{{this.rate}}</td>
                <td>₹{{this.amount}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="totals-section">
        <div class="totals-table">
            <div class="total-row"><span>Subtotal</span><span>₹{{subtotal}}</span></div>
            {{#if taxAmount}}<div class="total-row"><span>GST</span><span>₹{{taxAmount}}</span></div>{{/if}}
            <div class="total-row grand"><span>Credit Amount</span><span>₹{{totalAmount}}</span></div>
        </div>
    </div>

    <div class="note-section">
        <strong>Note:</strong> This credit note has been issued against Invoice No.
        <strong>{{originalInvoiceNumber}}</strong>. The credited amount will be adjusted against your next invoice or
        refunded as per mutual agreement. This credit note is valid for adjustment within 12 months from the date of
        issue.
    </div>

    <div class="signature-section">
        <div class="sig-block">
            <div class="sig-label">For {{companyName}}</div>
            <div class="sig-line">
                <div class="sig-name">Authorized Signatory</div>
                <div class="sig-role">Finance Department</div>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>This is a system-generated document. {{companyName}}</p>
    </div>
</body>

</html>