<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credit Note</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Dancing+Script:wght@600&display=swap" rel="stylesheet">
    <style>
        :root {
            --maroon: #801818;
            --text-dark: #1a1a1a;
            --text-muted: #666;
            --border-light: #e5e7eb;
            --bg-light: #f9fafb;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            line-height: 1.4;
            color: var(--text-dark);
            max-width: 800px;
            margin: 0 auto;
            padding: 0;
            background: white;
            font-size: 13px;
        }

        .page-header {
            background-color: var(--maroon);
            height: 20px;
            margin-bottom: 40px;
        }

        .container {
            padding: 0 50px 50px 50px;
        }

        .doc-title {
            font-size: 54px;
            font-weight: 300;
            letter-spacing: 2px;
            color: #333;
            margin-bottom: 40px;
            text-transform: uppercase;
        }

        .meta-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
            margin-bottom: 40px;
        }

        .meta-col h4 {
            font-size: 11px;
            font-weight: 700;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .meta-col p {
            font-size: 13px;
            color: #333;
            margin-bottom: 4px;
            line-height: 1.4;
        }

        .meta-col.right {
            text-align: right;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .meta-row {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        .meta-label {
            font-weight: 700;
            color: #999;
            font-size: 11px;
            text-transform: uppercase;
        }

        .meta-value {
            color: #333;
            font-weight: 600;
            width: 80px;
            text-align: right;
        }

        .divider {
            height: 1px;
            background-color: var(--border-light);
            margin: 20px 0;
        }

        .company-branding {
            text-align: center;
            margin: 40px 0;
        }

        .company-branding h1 {
            font-size: 36px;
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
        }

        .company-branding p {
            font-size: 14px;
            color: #666;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .items-table th {
            background-color: var(--maroon);
            color: white;
            text-align: left;
            padding: 12px 15px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .items-table th:not(:first-child) {
            text-align: right;
        }

        .items-table td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--border-light);
            color: #333;
        }

        .items-table td:not(:first-child) {
            text-align: right;
        }

        .items-table tr:nth-child(even) {
            background-color: #fefefe;
        }

        .totals-section {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            margin-top: 25px;
            gap: 10px;
        }

        .total-row {
            display: flex;
            justify-content: flex-end;
            width: 300px;
            font-size: 14px;
        }

        .total-row .label {
            font-weight: 700;
            color: #999;
            text-transform: uppercase;
            font-size: 12px;
            flex-grow: 1;
            text-align: right;
            padding-right: 20px;
        }

        .total-row .value {
            font-weight: 600;
            color: #333;
            width: 100px;
            text-align: right;
        }

        .grand-total {
            margin-top: 15px;
        }

        .grand-total .label {
            color: #999;
            font-size: 14px;
            font-weight: 400;
        }

        .grand-total .value {
            font-size: 20px;
            font-weight: 700;
            color: #000;
        }

        .signature-area {
            margin-top: 40px;
            text-align: right;
        }

        .signature-img {
            font-family: 'Dancing Script', cursive;
            font-size: 48px;
            color: #333;
            line-height: 1;
            margin-bottom: 10px;
        }

        .reason-box {
            margin-top: 50px;
            font-size: 12px;
            color: #666;
        }

        .reason-box h4 {
            font-size: 11px;
            font-weight: 700;
            color: #999;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .terms-section {
            margin-top: 40px;
        }

        .terms-section h4 {
            font-size: 12px;
            font-weight: 700;
            color: #999;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .terms-section p {
            font-size: 12px;
            color: #333;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .page-footer {
            background-color: var(--maroon);
            height: 20px;
            margin-top: 50px;
        }

        @media print {
            .page-header, .page-footer {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>

<body>
    <div class="page-header"></div>
    
    <div class="container">
        <h1 class="doc-title">Credit Note</h1>

        <div class="meta-grid">
            <div class="meta-col">
                <h4>Customer</h4>
                <p><strong>{{clientName}}</strong></p>
                <p>{{{clientAddress}}}</p>
            </div>
            <div class="meta-col">
                <h4>Ship To</h4>
                <p><strong>{{#if shipToName}}{{shipToName}}{{else}}{{clientName}}{{/if}}</strong></p>
                <p>{{#if shipToAddress}}{{{shipToAddress}}}{{else}}{{{clientAddress}}}{{/if}}</p>
            </div>
            <div class="meta-col right">
                <div class="meta-row">
                    <span class="meta-label">Credit Note #</span>
                    <span class="meta-value">{{creditNoteNumber}}</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">Credit Note Date</span>
                    <span class="meta-value">{{creditNoteDate}}</span>
                </div>
                {{#if poNumber}}
                <div class="meta-row">
                    <span class="meta-label">P.O. #</span>
                    <span class="meta-value">{{poNumber}}</span>
                </div>
                {{/if}}
                {{#if dueDate}}
                <div class="meta-row">
                    <span class="meta-label">Due Date</span>
                    <span class="meta-value">{{dueDate}}</span>
                </div>
                {{/if}}
                <div class="meta-row">
                    <span class="meta-label">Orig. Invoice #</span>
                    <span class="meta-value">{{invoiceNumber}}</span>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <div class="company-branding">
            <h1>{{companyName}}</h1>
            <p>{{{companyAddress}}}</p>
        </div>

        <table class="items-table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th>Unit Price</th>
                    <th>Qty</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                {{#each items}}
                <tr>
                    <td>{{this.description}}</td>
                    <td>{{this.unitPrice}}</td>
                    <td>{{this.quantity}}</td>
                    <td>{{this.amount}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <div class="totals-section">
            <div class="total-row">
                <span class="label">Subtotal</span>
                <span class="value">{{subtotal}}</span>
            </div>
            {{#if taxAmount}}
            <div class="total-row">
                <span class="label">Sales Tax {{#if taxRate}}{{taxRate}}%{{/if}}</span>
                <span class="value">{{taxAmount}}</span>
            </div>
            {{/if}}
            <div class="total-row grand-total">
                <span class="label">Credit Note Total</span>
                <span class="value">₹{{totalAmount}}</span>
            </div>
        </div>

        <div class="signature-area">
            <div class="signature-img">{{signatureName}}</div>
        </div>

        <div class="reason-box">
            <h4>Reason for Credit Note</h4>
            <p>{{reason}}</p>
        </div>

        <div class="terms-section">
            <h4>Terms & Conditions</h4>
            <p>{{#if terms}}{{terms}}{{else}}Payment is due within 15 days{{/if}}</p>
            {{#if companyName}}<p>Please make checks payable to: {{companyName}}</p>{{/if}}
        </div>
    </div>

    <div class="page-footer"></div>
</body>

</html>