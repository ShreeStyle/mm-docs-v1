<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Receipt</title>
    <style>
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #333;
            background-color: #fff;
            line-height: 1.6;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0;
            border: 1px solid #eee;
        }
        .header {
            background-color: #2563eb;
            color: white;
            padding: 40px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .header-left h1 {
            margin: 0;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .header-left p {
            margin: 10px 0 0 0;
            opacity: 0.9;
            font-size: 14px;
            max-width: 300px;
        }
        .header-right {
            text-align: right;
        }
        .header-right .receipt-label {
            font-size: 12px;
            opacity: 0.8;
            text-transform: uppercase;
        }
        .header-right .receipt-number {
            font-size: 20px;
            font-weight: 700;
            margin-top: 5px;
        }
        .content {
            padding: 40px;
        }
        .meta-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }
        .meta-section h3 {
            margin: 0 0 10px 0;
            font-size: 12px;
            text-transform: uppercase;
            color: #666;
            border-bottom: 2px solid #2563eb;
            display: inline-block;
            padding-bottom: 2px;
        }
        .meta-section p {
            margin: 5px 0;
            font-size: 15px;
            font-weight: 600;
        }
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        .items-table th {
            background-color: #1e293b;
            color: white;
            text-align: left;
            padding: 12px 15px;
            font-size: 13px;
            text-transform: uppercase;
        }
        .items-table td {
            padding: 15px;
            border-bottom: 1px solid #eee;
            font-size: 14px;
        }
        .text-right { text-align: right; }
        .summary {
            margin-left: auto;
            width: 300px;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 14px;
        }
        .summary-row.total {
            border-top: 2px solid #2563eb;
            margin-top: 10px;
            padding-top: 15px;
            font-weight: 800;
            font-size: 20px;
            color: #2563eb;
        }
        .extra-info {
            margin-top: 50px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }
        .extra-info-box h4 {
            margin: 0 0 10px 0;
            font-size: 12px;
            text-transform: uppercase;
            color: #666;
        }
        .extra-info-box p {
            font-size: 13px;
            color: #444;
            white-space: pre-wrap;
        }
        .footer {
            background-color: #f8fafc;
            padding: 30px 40px;
            border-top: 1px solid #e2e8f0;
            text-align: center;
        }
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 10px;
            font-size: 13px;
            color: #64748b;
        }
        .footer-tagline {
            font-size: 12px;
            color: #94a3b8;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <h1>{{company_name}}</h1>
                <p>{{company_address}}</p>
            </div>
            <div class="header-right">
                <div class="receipt-label">Receipt Number</div>
                <div class="receipt-number">{{receipt_number}}</div>
                <div class="receipt-label" style="margin-top: 15px;">Date</div>
                <div class="receipt-number" style="font-size: 16px;">{{receipt_date}}</div>
            </div>
        </div>

        <div class="content">
            <div class="meta-grid">
                <div class="meta-section">
                    <h3>Sent To</h3>
                    <p>{{client_name}}</p>
                    <p style="font-weight: 400; color: #666; font-size: 14px;">{{client_address}}</p>
                </div>
                <div class="meta-section">
                    <!-- Placeholder or additional info if needed -->
                </div>
            </div>

            <table class="items-table">
                <thead>
                    <tr>
                        <th width="10%">Qty</th>
                        <th width="50%">Description</th>
                        <th width="20%" class="text-right">Unit Price</th>
                        <th width="20%" class="text-right">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                    <tr>
                        <td>{{qty}}</td>
                        <td>{{description}}</td>
                        <td class="text-right">{{currency_symbol}}{{unit_price}}</td>
                        <td class="text-right">{{currency_symbol}}{{total}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <div class="summary">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>₹{{subtotal}}</span>
                </div>
                <div class="summary-row">
                    <span>Tax</span>
                    <span>₹{{tax}}</span>
                </div>
                <div class="summary-row total">
                    <span>Total Amount</span>
                    <span>₹{{total}}</span>
                </div>
            </div>

            <div class="extra-info">
                <div class="extra-info-box">
                    <h4>Bank Information</h4>
                    <p>
                        <strong>Bank:</strong> {{bank_name}}<br>
                        <strong>A/C Name:</strong> {{bank_account_name}}<br>
                        <strong>A/C No:</strong> {{bank_account_number}}<br>
                        <strong>IFSC:</strong> {{bank_ifsc}}<br>
                        {{#if bank_upi}}<strong>UPI:</strong> {{bank_upi}}{{/if}}
                    </p>
                </div>
                {{#if terms}}
                <div class="extra-info-box">
                    <h4>Terms & Conditions</h4>
                    <p>{{terms}}</p>
                </div>
                {{/if}}
            </div>
        </div>

        <div class="footer">
            <div class="footer-links">
                {{#if footerPhone}}<span>T: {{footerPhone}}</span>{{/if}}
                {{#if footerEmail}}<span>E: {{footerEmail}}</span>{{/if}}
                {{#if footerWebsite}}<span>W: {{footerWebsite}}</span>{{/if}}
            </div>
            <div class="footer-tagline">Thank you for your business!</div>
        </div>
    </div>
</body>
</html>
