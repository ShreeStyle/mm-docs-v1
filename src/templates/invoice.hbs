<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Dancing+Script:wght@600&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            color: #1a1a1a;
            line-height: 1.4;
            margin: 0;
            padding: 80px 60px;
            background: #fff;
        }

        .invoice-container {
            max-width: 800px;
            margin: 0 auto;
        }

        /* Top Header Section */
        .top-header {
            display: flex;
            align-items: center;
            margin-bottom: 80px;
        }

        .header-line {
            flex-grow: 1;
            height: 1px;
            background-color: #000;
            margin-right: 20px;
        }

        .invoice-label {
            font-size: 54px;
            font-weight: 300;
            letter-spacing: 18px;
            color: #1a1a1a;
            text-transform: uppercase;
        }

        /* Info Grid Section */
        .info-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 60px;
        }

        .left-info {
            width: 50%;
        }

        .right-info {
            text-align: right;
            width: 40%;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .label-block {
            margin-bottom: 25px;
        }

        .section-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            margin-bottom: 5px;
            display: block;
        }

        .info-text {
            font-size: 13px;
            color: #333;
            margin: 0;
            display: block;
        }

        .meta-row {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            font-size: 13px;
        }

        .meta-label {
            font-weight: 700;
            letter-spacing: 0.5px;
            width: 100px;
            text-align: right;
        }

        .meta-value {
            width: 80px;
            text-align: right;
        }

        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 0px;
            border-bottom: 1px solid #000;
        }

        .items-table th {
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            padding: 15px 0;
            border-bottom: 2px solid #000;
            text-transform: uppercase;
        }

        .items-table td {
            padding: 20px 0;
            font-size: 14px;
            color: #333;
            vertical-align: top;
        }

        .items-table .unit-price, 
        .items-table .qty, 
        .items-table .total-col {
            text-align: center;
            width: 100px;
        }

        .items-table .total-col {
            text-align: right;
        }

        /* Totals Section */
        .totals-container {
            margin-top: 20px;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 8px;
        }

        .total-row {
            display: flex;
            justify-content: flex-end;
            width: 250px;
            font-size: 13px;
        }

        .total-row .label {
            font-weight: 700;
            letter-spacing: 1px;
            flex-grow: 1;
            text-align: left;
            text-transform: uppercase;
        }

        .total-row .value {
            text-align: right;
            width: 80px;
        }

        .grand-total {
            font-size: 15px;
            margin-top: 5px;
        }

        .grand-total .label {
            font-size: 14px;
        }

        .grand-total .value {
            font-weight: 800;
        }

        /* Signature Section */
        .signature-container {
            margin-top: 100px;
            text-align: right;
        }

        .signature-img {
            font-family: 'Dancing Script', cursive;
            font-size: 42px;
            color: #333;
            margin-bottom: 0px;
            display: inline-block;
            border-bottom: 1px solid transparent;
            line-height: 1;
        }

        .signature-line {
            display: none; /* Reference doesn't have a visible line under it, just the name */
        }
    </style>
</head>
<body>
    <div class="invoice-container">
        <!-- Header -->
        <div class="top-header">
            <div class="header-line"></div>
            <div class="invoice-label">INVOICE</div>
        </div>

        <!-- Meta Info -->
        <div class="info-section">
            <div class="left-info">
                <div class="label-block">
                    <span class="section-label">ISSUED TO:</span>
                    <span class="info-text">{{client_name}}</span>
                    <span class="info-text">{{client_company}}</span>
                    <span class="info-text">{{client_address}}</span>
                </div>

                <div class="label-block">
                    <span class="section-label">PAY TO:</span>
                    <span class="info-text">{{bank_name}}</span>
                    <span class="info-text">Account Name: {{bank_account_name}}</span>
                    <span class="info-text">Account No.: {{bank_account_number}}</span>
                </div>
            </div>

            <div class="right-info">
                <div class="meta-row">
                    <div class="meta-label">INVOICE NO:</div>
                    <div class="meta-value">{{invoice_number}}</div>
                </div>
                <div class="meta-row">
                    <div class="meta-label">DATE:</div>
                    <div class="meta-value">{{invoice_date}}</div>
                </div>
                <div class="meta-row">
                    <div class="meta-label">DUE DATE:</div>
                    <div class="meta-value">{{due_date}}</div>
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <table class="items-table">
            <thead>
                <tr>
                    <th>DESCRIPTION</th>
                    <th class="unit-price">UNIT PRICE</th>
                    <th class="qty">QTY</th>
                    <th class="total-col">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                {{#each items}}
                <tr>
                    <td>{{description}}</td>
                    <td class="unit-price">{{unit_price}}</td>
                    <td class="qty">{{qty}}</td>
                    <td class="total-col">₹{{total}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <!-- Totals -->
        <div class="totals-container">
            <div class="total-row">
                <div class="label">SUBTOTAL</div>
                <div class="value">₹{{subtotal}}</div>
            </div>
            <div class="total-row">
                <div class="label" style="text-align: right; padding-right: 40px; text-transform: none; font-weight: 400; color: #666;">Tax</div>
                <div class="label" style="width: auto; text-align: left; text-transform: none; font-weight: 400; color: #666;">{{tax_percentage}}%</div>
                <div class="value" style="color: #666;">₹{{tax_amount}}</div>
            </div>
            <div class="total-row grand-total">
                <div class="label">TOTAL</div>
                <div class="value">₹{{total_amount}}</div>
            </div>
        </div>

        <!-- Signature -->
        <div class="signature-container">
            <div class="signature-img">{{signatory_name}}</div>
        </div>
    </div>
</body>
</html>

</html>