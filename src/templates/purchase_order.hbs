<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Purchase Order</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            line-height: 1.4;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            background: white;
            font-size: 11px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
        }

        .company-info {
            flex: 1;
        }

        .company-name {
            font-size: 24px;
            font-weight: 400;
            color: #333;
            margin-bottom: 10px;
            font-family: 'Inter', sans-serif;
        }

        .company-details {
            color: #666;
            line-height: 1.6;
            white-space: pre-line;
        }

        .doc-title-container {
            text-align: right;
        }

        .doc-title {
            font-size: 32px;
            font-weight: 700;
            color: #7290C1; /* Light blue color from reference */
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .po-meta-table {
            border-collapse: collapse;
            float: right;
        }

        .po-meta-table td {
            border: 1px solid #ccc;
            padding: 4px 15px;
            text-align: right;
            font-size: 11px;
        }

        .po-meta-table .label {
            background-color: #f9f9f9;
            text-align: left;
            width: 80px;
            color: #666;
        }

        .po-meta-table .value {
            width: 120px;
            text-align: center;
        }

        .clear {
            clear: both;
        }

        .parties-sections {
            display: flex;
            justify-content: space-between;
            gap: 40px;
            margin-bottom: 25px;
            margin-top: 20px;
        }

        .party-box {
            flex: 1;
        }

        .party-header {
            background-color: #3B548E; /* Dark blue from reference */
            color: white;
            padding: 5px 15px;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .party-content {
            padding: 0 5px;
            color: #333;
            white-space: pre-line;
            line-height: 1.6;
        }

        .logistics-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        .logistics-table th {
            background-color: #3B548E;
            color: white;
            text-align: center;
            padding: 5px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid #3B548E;
        }

        .logistics-table td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
            height: 35px;
            width: 25%;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .items-table th {
            background-color: #3B548E;
            color: white;
            text-align: center;
            padding: 8px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid #3B548E;
        }

        .items-table td {
            border: 1px solid #ccc;
            padding: 8px;
            min-height: 30px;
        }

        .items-table .col-item { width: 15%; text-align: center; }
        .items-table .col-desc { width: 45%; }
        .items-table .col-qty { width: 10%; text-align: center; }
        .items-table .col-price { width: 15%; text-align: right; }
        .items-table .col-total { width: 15%; text-align: right; background-color: #f9f9f9; }

        .items-table tbody tr {
            height: 30px;
        }

        .totals-container {
            display: flex;
            justify-content: flex-end;
            margin-top: -21px; /* Overlap with table border */
        }

        .totals-table {
            width: 200px;
            border-collapse: collapse;
        }

        .totals-table td {
            border: 1px solid #ccc;
            padding: 6px 10px;
            text-align: right;
        }

        .totals-table .label {
            background-color: #f9f9f9;
            color: #666;
            font-weight: 400;
            text-align: left;
            width: 100px;
        }

        .totals-table .total-row {
            background-color: #7290C1;
            color: white;
            font-weight: 700;
        }

        .totals-table .total-row-value {
            background-color: #7290C1;
            color: white;
            font-weight: 700;
        }

        .comments-section {
            margin-top: 30px;
            width: 55%;
        }

        .comments-header {
            background-color: #ccc;
            color: #333;
            padding: 4px 10px;
            font-weight: 700;
            font-size: 11px;
            border: 1px solid #ccc;
        }

        .comments-box {
            border: 1px solid #ccc;
            min-height: 100px;
            padding: 10px;
            color: #333;
        }

        .footer {
            margin-top: 60px;
            text-align: center;
            color: #333;
            font-size: 11px;
        }

        .footer-contact {
            margin-top: 5px;
            font-weight: 400;
        }

        /* Create extra empty rows to fill a4 if items list is short */
        .empty-row {
            height: 30px;
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="company-info">
            <div class="company-name">{{#if company_name}}{{company_name}}{{else}}[Company Name]{{/if}}</div>
            <div class="company-details">
                {{#if company_address}}{{{company_address}}}{{else}}[Street Address]
[City, ST ZIP]{{/if}}
                {{#if company_phone}}Phone: {{company_phone}}{{/if}}
                {{#if company_fax}}Fax: {{company_fax}}{{/if}}
                {{#if company_website}}Website: {{company_website}}{{/if}}
            </div>
        </div>
        <div class="doc-title-container">
            <div class="doc-title">PURCHASE ORDER</div>
            <table class="po-meta-table">
                <tr>
                    <td class="label">DATE</td>
                    <td class="value">{{#if document_date}}{{document_date}}{{else}}9/17/2015{{/if}}</td>
                </tr>
                <tr>
                    <td class="label">PO #</td>
                    <td class="value">{{#if purchase_order_number}}{{purchase_order_number}}{{else}}[123456]{{/if}}</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="clear"></div>

    <div class="parties-sections">
        <div class="party-box">
            <div class="party-header">VENDOR</div>
            <div class="party-content">
                {{#if vendor_name}}<strong>{{vendor_name}}</strong>{{else}}[Company Name]{{/if}}
                {{#if vendor_contact_person}}{{{vendor_contact_person}}}{{else}}[Contact or Department]{{/if}}
                {{#if vendor_address}}{{{vendor_address}}}{{else}}[Street Address]
[City, ST ZIP]{{/if}}
                {{#if vendor_phone}}Phone: {{vendor_phone}}{{/if}}
                {{#if vendor_fax}}Fax: {{vendor_fax}}{{/if}}
            </div>
        </div>
        <div class="party-box">
            <div class="party-header">SHIP TO</div>
            <div class="party-content">
                {{#if ship_to_name}}<strong>{{ship_to_name}}</strong>{{else}}[Name]{{/if}}
                {{#if ship_to_company_name}}{{{ship_to_company_name}}}{{else}}[Company Name]{{/if}}
                {{#if ship_to_address}}{{{ship_to_address}}}{{else}}[Street Address]
[City, ST ZIP]{{/if}}
                {{#if ship_to_phone}}Phone: {{ship_to_phone}}{{/if}}
            </div>
        </div>
    </div>

    <table class="logistics-table">
        <thead>
            <tr>
                <th>REQUISITIONER</th>
                <th>SHIP VIA</th>
                <th>F.O.B.</th>
                <th>SHIPPING TERMS</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>{{requisitioner}}</td>
                <td>{{ship_via}}</td>
                <td>{{fob}}</td>
                <td>{{shipping_terms}}</td>
            </tr>
        </tbody>
    </table>

    <table class="items-table">
        <thead>
            <tr>
                <th class="col-item">ITEM #</th>
                <th class="col-desc">DESCRIPTION</th>
                <th class="col-qty">QTY</th>
                <th class="col-price">UNIT PRICE</th>
                <th class="col-total">TOTAL</th>
            </tr>
        </thead>
        <tbody>
            {{#if items}}
                {{#each items}}
                <tr>
                    <td class="col-item">{{this.item_number}}</td>
                    <td class="col-desc">{{this.description}}</td>
                    <td class="col-qty">{{this.quantity}}</td>
                    <td class="col-price">{{this.unit_price}}</td>
                    <td class="col-total">{{this.total}}</td>
                </tr>
                {{/each}}
            {{else}}
                <tr>
                    <td class="col-item">[23423423]</td>
                    <td class="col-desc">Product XYZ</td>
                    <td class="col-qty">15</td>
                    <td class="col-price">150.00</td>
                    <td class="col-total">2,250.00</td>
                </tr>
                <tr>
                    <td class="col-item">[45645645]</td>
                    <td class="col-desc">Product ABC</td>
                    <td class="col-qty">1</td>
                    <td class="col-price">75.00</td>
                    <td class="col-total">75.00</td>
                </tr>
            {{/if}}
            
            {{!-- Empty rows to maintain table structure if few items --}}
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
            <tr class="empty-row"><td class="col-item"></td><td class="col-desc"></td><td class="col-qty"></td><td class="col-price"></td><td class="col-total">-</td></tr>
        </tbody>
    </table>

    <div class="totals-container">
        <table class="totals-table">
            <tr>
                <td class="label">SUBTOTAL</td>
                <td>{{#if subtotal}}{{subtotal}}{{else}}2,325.00{{/if}}</td>
            </tr>
            <tr>
                <td class="label">TAX</td>
                <td>{{#if tax}}{{tax}}{{else}}-{{/if}}</td>
            </tr>
            <tr>
                <td class="label">SHIPPING</td>
                <td>{{#if shipping}}{{shipping}}{{else}}-{{/if}}</td>
            </tr>
            <tr>
                <td class="label">OTHER</td>
                <td>{{#if other}}{{other}}{{else}}-{{/if}}</td>
            </tr>
            <tr class="total-row">
                <td class="label total-row">TOTAL</td>
                <td class="total-row-value">$ {{#if total}}{{total}}{{else}}2,325.00{{/if}}</td>
            </tr>
        </table>
    </div>

    <div class="comments-section">
        <div class="comments-header">Comments or Special Instructions</div>
        <div class="comments-box">
            {{comments}}
        </div>
    </div>

    <div class="footer">
        <div>If you have any questions about this purchase order, please contact</div>
        <div class="footer-contact">[{{#if company_contact_person}}{{company_contact_person}}{{else}}Name{{/if}}, {{#if company_phone}}{{company_phone}}{{else}}Phone #{{/if}}, {{#if company_email}}{{company_email}}{{else}}E-mail{{/if}}]</div>
    </div>
</body>

</html>