# JWT Secret for Authentication
JWT_SECRET=your_jwt_secret_key_here

# OpenAI/OpenRouter API Key (for AI document generation)
# Use OpenRouter key (starts with sk-or-v1-) or OpenAI key
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_API_KEY_BACKUP=your-backup-key-here

# MongoDB Connection (Using the shared Cloud Atlas Cluster)
MONGODB_URI=mongodb+srv://bhatiyakavya695_db_user:NHhzSv365iOm1mJR@cluster0.f5kfgha.mongodb.net/aidocumentation?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=mongodb+srv://bhatiyakavya695_db_user:NHhzSv365iOm1mJR@cluster0.f5kfgha.mongodb.net/aidocumentation?retryWrites=true&w=majority&appName=Cluster0

# Razorpay Payment Gateway (for Pro Subscriptions)
# Get these from https://dashboard.razorpay.com/app/website-app-settings/api-keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (for document invitations and notifications)
# Option 1: Gmail (recommended for testing)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Option 2: Custom SMTP (optional)
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Email sender name (optional, defaults to "MM Docs")
EMAIL_FROM=MM Docs <your-email@gmail.com>
